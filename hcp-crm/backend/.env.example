# Groq API key - create one at https://console.groq.com/keys
# GROQ_API_KEY=your_groq_api_key

# Primary model (fast, cheap) and a stronger model used for context/fallback
# GROQ_PRIMARY_MODEL=gemma2-9b-it
# GROQ_FALLBACK_MODEL=llama-3.3-70b-versatile

# Database
# Default: SQLite, zero setup, great for running the assignment locally.
# DATABASE_URL=sqlite:///./hcp_1crm.db

# To use Postgres instead:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/hcp_crm

# To use MySQL instead:
# DATABASE_URL=mysql+pymysql://root:root@localhost:3306/hcp_crm

# CORS - the frontend origin
# FRONTEND_ORIGIN=http://localhost:5173
